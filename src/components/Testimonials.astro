---
// Testimonials.astro

const reviews = [
  {
    name: "Alejandro Ramos",
    role: "Inversionista Patrimonial",
    initials: "AR",
    avatarBg: "bg-olive-500/10 text-olive-600",
    text: "Adquirir en la fase de pre-venta con Coronado Real Estate ha sido mi mejor decisión de inversión de este año. La plusvalía en la zona norte de Saltillo crece constantemente y el proyecto de urbanización es impecable.",
    rating: 5
  },
  {
    name: "Mariela Ortiz",
    role: "Próxima Residente",
    initials: "MO",
    avatarBg: "bg-gold-500/20 text-gold-600",
    text: "Buscábamos un lugar seguro y pacífico para nuestra familia. Nos convenció el diseño con cableado subterráneo porque preserva totalmente la vista limpia de las montañas. El trato fue sumamente transparente.",
    rating: 5
  },
  {
    name: "Gerardo Valdés",
    role: "Comprador de Lote",
    initials: "GV",
    avatarBg: "bg-olive-500/10 text-olive-600",
    text: "La atención por WhatsApp fue muy ágil y profesional. Me explicaron las opciones de enganche y financiamiento directo detalladamente. Agendamos la visita el mismo fin de semana y ya apartamos nuestro lote.",
    rating: 5
  }
];
---

<section id="testimonios" class="relative py-24 bg-bone overflow-hidden z-20">
  <!-- Visual Accent Bloom -->
  <div class="absolute top-10 left-10 w-72 h-72 rounded-full bg-gold-500/5 blur-[80px] pointer-events-none"></div>

  <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="text-gold-600 font-sans font-semibold text-xs tracking-widest uppercase block mb-3">Testimonios Reales</span>
      <h2 class="text-charcoal text-3xl sm:text-4xl md:text-5xl font-bold font-serif mb-6 leading-tight">
        La confianza de nuestros clientes
      </h2>
      <p class="text-charcoal/70 font-sans text-sm md:text-base leading-relaxed">
        Descubre por qué familias e inversionistas eligen Coronado Real Estate para cimentar su futuro y asegurar su patrimonio en Saltillo.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map((rev, index) => (
        <div 
          class="glass-card rounded-[32px] p-8 shadow-md hover:shadow-xl border border-gold-500/10 hover:border-gold-500/30 transition-all duration-300 flex flex-col justify-between reveal"
          style={`transition-delay: ${100 * (index + 1)}ms;`}
        >
          <!-- Top Row: Rating & Quote -->
          <div>
            <!-- Stars -->
            <div class="flex items-center gap-1 mb-6 text-gold-500">
              {Array.from({ length: rev.rating }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            
            <!-- Comment Text -->
            <blockquote class="text-charcoal/80 font-sans text-sm italic leading-relaxed mb-8">
              "{rev.text}"
            </blockquote>
          </div>

          <!-- Bottom Row: Client Info -->
          <div class="flex items-center gap-4 pt-6 border-t border-charcoal/10">
            <!-- Initials Avatar -->
            <div class={`w-12 h-12 rounded-full flex items-center justify-center font-serif font-bold text-base shrink-0 shadow-inner ${rev.avatarBg}`}>
              {rev.initials}
            </div>
            <div>
              <cite class="not-italic font-serif font-bold text-charcoal text-sm block">
                {rev.name}
              </cite>
              <span class="font-sans text-[10px] text-charcoal/50 uppercase tracking-wider block mt-0.5">
                {rev.role}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
