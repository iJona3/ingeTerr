---
// SlantedBenefits.astro
import { Image } from 'astro:assets';
import benefitImg1 from '../assets/images/4664131bf6c7861d8cc19f32b744394a.jpg';
import benefitImg2 from '../assets/images/b34bc8bd20cbe72fdc80906ce4b9ff97.jpg';
---

<section 
  id="beneficios" 
  class="relative py-32 bg-bone overflow-hidden z-20"
>
  <!-- Slanted Section Separator (Visual Cut) -->
  <div class="absolute inset-0 bg-olive-50/50 clip-slant-down -z-10 border-t border-b border-gold-500/10"></div>

  <!-- Background decorative bloom -->
  <div class="absolute top-1/3 left-[-10%] w-[30vw] h-[30vw] rounded-full bg-gold-500/10 blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto px-4 md:px-8 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 items-center">
      
      <!-- Image Stack Column (Left on desktop, bottom on mobile) -->
      <div class="lg:col-span-5 relative flex justify-center order-2 lg:order-1 reveal-left">
        <!-- Layered Photo Stack -->
        <div class="relative w-full max-w-[360px] aspect-[4/5]">
          <!-- Back Card (Decorative frame) -->
          <div class="absolute inset-0 bg-olive-500/5 border border-olive-500/10 rounded-[32px] transform -rotate-[5deg] scale-105"></div>
          
          <!-- Base Image (Main) -->
          <div class="absolute inset-0 rounded-[32px] overflow-hidden shadow-xl border-4 border-bone transform -rotate-[2deg] hover:rotate-0 transition-transform duration-500 cursor-pointer">
            <Image 
              src={benefitImg1} 
              alt="Terreno urbanizado en Saltillo" 
              class="w-full h-full object-cover" 
              width={600}
              height={750}
            />
          </div>
          
          <!-- Overlapping Image (Smaller) -->
          <div class="absolute -bottom-10 -right-6 md:-right-10 w-[60%] aspect-square rounded-2xl overflow-hidden shadow-2xl border-4 border-bone transform rotate-[6deg] hover:rotate-0 transition-transform duration-500 cursor-pointer z-10">
            <Image 
              src={benefitImg2} 
              alt="Detalles de urbanización" 
              class="w-full h-full object-cover" 
              width={360}
              height={360}
            />
          </div>
                    <!-- Decorative stamp/badge -->
          <div class="absolute -top-6 -left-6 w-20 h-20 rounded-full bg-gold-500/10 border border-gold-500/30 flex items-center justify-center text-gold-600 font-serif font-bold text-xs uppercase tracking-widest text-center transform -rotate-12 animate-float">
            <span class="lang-es">Calidad<br/>Premium</span>
            <span class="lang-en">Premium<br/>Quality</span>
          </div>
        </div>
      </div>
      
      <!-- Text/Benefits Column (Right) -->
      <div class="lg:col-span-7 flex flex-col items-start order-1 lg:order-2 reveal-right">
        <span class="text-gold-600 font-sans font-semibold text-xs tracking-widest uppercase block mb-3">
          <span class="lang-es">¿Por qué Elegir Coronado Real Estate?</span>
          <span class="lang-en">Why Choose Coronado Real Estate?</span>
        </span>
        <h2 class="text-charcoal text-3xl sm:text-4xl md:text-5xl font-bold font-serif mb-8 leading-tight">
          <span class="lang-es">Tu inversión segura en la zona de mayor crecimiento</span>
          <span class="lang-en">Your Secure Investment in the Fastest Growing Area</span>
        </h2>
        
        <!-- Benefits List -->
        <div class="space-y-8 w-full">
          
          <!-- Benefit 1 -->
          <div class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-olive-500/10 border border-olive-500/20 flex items-center justify-center text-olive-600 shrink-0 group-hover:bg-olive-500 group-hover:text-bone transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-charcoal font-serif font-bold text-lg mb-2 group-hover:text-olive-600 transition-colors">
                <span class="lang-es">Plusvalía Saltillo</span><span class="lang-en">Saltillo Appreciation</span>
              </h3>
              <p class="text-charcoal/70 font-sans text-sm leading-relaxed">
                <span class="lang-es">Saltillo se consolida como uno de los polos industriales y residenciales más dinámicos de México. Adquirir en fase de pre-venta te garantiza el mayor margen de apreciación desde el día uno.</span>
                <span class="lang-en">Saltillo is established as one of the most dynamic industrial and residential hubs in Mexico. Purchasing in the pre-sale phase guarantees you the highest appreciation margin from day one.</span>
              </p>
            </div>
          </div>
          
          <!-- Benefit 2 -->
          <div class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-olive-500/10 border border-olive-500/20 flex items-center justify-center text-olive-600 shrink-0 group-hover:bg-olive-500 group-hover:text-bone transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-charcoal font-serif font-bold text-lg mb-2 group-hover:text-olive-600 transition-colors">
                <span class="lang-es">Conectividad Estratégica</span><span class="lang-en">Strategic Connectivity</span>
              </h3>
              <p class="text-charcoal/70 font-sans text-sm leading-relaxed">
                <span class="lang-es">Ubicación privilegiada en una zona residencial en auge, con accesos rápidos a las principales arterias de la ciudad, colegios de primer nivel, supermercados y centros de salud.</span>
                <span class="lang-en">Privileged location in a booming residential area, with quick access to the city's main avenues, top-tier schools, supermarkets, and healthcare facilities.</span>
              </p>
            </div>
          </div>
          
          <!-- Benefit 3 -->
          <div class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-olive-500/10 border border-olive-500/20 flex items-center justify-center text-olive-600 shrink-0 group-hover:bg-olive-500 group-hover:text-bone transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <div>
              <h3 class="text-charcoal font-serif font-bold text-lg mb-2 group-hover:text-olive-600 transition-colors">
                <span class="lang-es">Certeza Jurídica Total</span><span class="lang-en">Total Legal Certainty</span>
              </h3>
              <p class="text-charcoal/70 font-sans text-sm leading-relaxed">
                <span class="lang-es">Desarrollo completamente regularizado con escrituración directa y todos los permisos municipales en regla. Tu inversión está respaldada legalmente de principio a fin.</span>
                <span class="lang-en">Fully regularized development with direct deed registration and all municipal permits in order. Your investment is legally backed from start to finish.</span>
              </p>
            </div>
          </div>
          </div>
          
        </div>
      </div>
      
    </div>
  </div>
</section>
