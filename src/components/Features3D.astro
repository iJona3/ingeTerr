---
// Features3D.astro
---

<section id="amenidades" class="relative py-24 bg-earth overflow-hidden z-20">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-1/4 w-96 h-96 rounded-full bg-olive-500/5 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-10 w-80 h-80 rounded-full bg-gold-500/5 blur-[90px] pointer-events-none"></div>

  <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="text-gold-600 font-sans font-semibold text-xs tracking-widest uppercase block mb-3">
        <span class="lang-es">Amenidades Exclusivas</span><span class="lang-en">Exclusive Amenities</span>
      </span>
      <h2 class="text-charcoal text-3xl sm:text-4xl md:text-5xl font-bold font-serif mb-6 leading-tight">
        <span class="lang-es">Diseñado para elevar tu estilo de vida</span>
        <span class="lang-en">Designed to Elevate Your Lifestyle</span>
      </h2>
      <p class="text-charcoal/70 font-sans text-sm md:text-base leading-relaxed">
        <span class="lang-es">Cada rincón de Coronado Real Estate ha sido planificado meticulosamente para ofrecerte la combinación perfecta de lujo, seguridad y naturaleza.</span>
        <span class="lang-en">Every corner of Coronado Real Estate has been meticulously planned to offer you the perfect blend of luxury, safety, and nature.</span>
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 perspective-3d">
      
      <!-- Card 1: Servicios Subterráneos -->
      <div class="tilt-card glass-card rounded-[32px] p-8 shadow-md hover:shadow-2xl transition-all duration-300 transform-gpu preserve-3d cursor-pointer flex flex-col justify-between min-h-[350px] border border-gold-500/10 hover:border-gold-500/30 group reveal" style="transition-delay: 100ms;">
        <div>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-olive-500/10 flex items-center justify-center text-olive-600 mb-8 transform-gpu transition-all duration-300 group-hover:scale-110 group-hover:bg-olive-500 group-hover:text-bone shadow-sm" style="transform: translateZ(20px);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <!-- Title -->
          <h3 class="text-charcoal font-serif font-bold text-xl mb-4 transform-gpu transition-transform duration-300 group-hover:translate-x-1" style="transform: translateZ(25px);">
            <span class="lang-es">Servicios Subterráneos</span><span class="lang-en">Underground Utilities</span>
          </h3>
          <!-- Text -->
          <p class="text-charcoal/70 font-sans text-sm leading-relaxed" style="transform: translateZ(15px);">
            <span class="lang-es">Instalaciones ocultas de agua, luz y fibra óptica para mantener la armonía visual y la majestuosa vista de la sierra de Saltillo.</span>
            <span class="lang-en">Hidden water, power, and fiber optic installations to preserve visual harmony and the majestic views of the Saltillo mountains.</span>
          </p>
        </div>
        <div class="mt-6 flex items-center text-xs font-semibold text-olive-600 group-hover:text-olive-500 gap-1" style="transform: translateZ(20px);">
          <span class="lang-es">Más detalles</span><span class="lang-en">More details</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

      <!-- Card 2: Seguridad 24/7 -->
      <div class="tilt-card glass-card rounded-[32px] p-8 shadow-md hover:shadow-2xl transition-all duration-300 transform-gpu preserve-3d cursor-pointer flex flex-col justify-between min-h-[350px] border border-gold-500/10 hover:border-gold-500/30 group reveal" style="transition-delay: 200ms;">
        <div>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-olive-500/10 flex items-center justify-center text-olive-600 mb-8 transform-gpu transition-all duration-300 group-hover:scale-110 group-hover:bg-olive-500 group-hover:text-bone shadow-sm" style="transform: translateZ(20px);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <!-- Title -->
          <h3 class="text-charcoal font-serif font-bold text-xl mb-4 transform-gpu transition-transform duration-300 group-hover:translate-x-1" style="transform: translateZ(25px);">
            <span class="lang-es">Privada con Acceso Controlado</span><span class="lang-en">Gated & Access Control</span>
          </h3>
          <!-- Text -->
          <p class="text-charcoal/70 font-sans text-sm leading-relaxed" style="transform: translateZ(15px);">
            <span class="lang-es">Caseta de vigilancia blindada, cámaras de circuito cerrado inteligente y control de accesos automatizado las 24 horas del día.</span>
            <span class="lang-en">Armored guardhouse, smart closed-circuit cameras, and automated access control 24 hours a day.</span>
          </p>
        </div>
        <div class="mt-6 flex items-center text-xs font-semibold text-olive-600 group-hover:text-olive-500 gap-1" style="transform: translateZ(20px);">
          <span class="lang-es">Más detalles</span><span class="lang-en">More details</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

      <!-- Card 3: Áreas Verdes -->
      <div class="tilt-card glass-card rounded-[32px] p-8 shadow-md hover:shadow-2xl transition-all duration-300 transform-gpu preserve-3d cursor-pointer flex flex-col justify-between min-h-[350px] border border-gold-500/10 hover:border-gold-500/30 group reveal" style="transition-delay: 300ms;">
        <div>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-olive-500/10 flex items-center justify-center text-olive-600 mb-8 transform-gpu transition-all duration-300 group-hover:scale-110 group-hover:bg-olive-500 group-hover:text-bone shadow-sm" style="transform: translateZ(20px);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z" />
            </svg>
          </div>
          <!-- Title -->
          <h3 class="text-charcoal font-serif font-bold text-xl mb-4 transform-gpu transition-transform duration-300 group-hover:translate-x-1" style="transform: translateZ(25px);">
            <span class="lang-es">Áreas Verdes Equipadas</span><span class="lang-en">Equipped Green Areas</span>
          </h3>
          <!-- Text -->
          <p class="text-charcoal/70 font-sans text-sm leading-relaxed" style="transform: translateZ(15px);">
            <span class="lang-es">Parques arbolados con juegos infantiles, andadores para caminatas ecológicas y áreas de relajación perfectamente jardinadas.</span>
            <span class="lang-en">Wooded parks with playgrounds, trails for ecological walks, and perfectly landscaped relaxation areas.</span>
          </p>
        </div>
        <div class="mt-6 flex items-center text-xs font-semibold text-olive-600 group-hover:text-olive-500 gap-1" style="transform: translateZ(20px);">
          <span class="lang-es">Más detalles</span><span class="lang-en">More details</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

      <!-- Card 4: Casa Club -->
      <div class="tilt-card glass-card rounded-[32px] p-8 shadow-md hover:shadow-2xl transition-all duration-300 transform-gpu preserve-3d cursor-pointer flex flex-col justify-between min-h-[350px] border border-gold-500/10 hover:border-gold-500/30 group reveal" style="transition-delay: 400ms;">
        <div>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-olive-500/10 flex items-center justify-center text-olive-600 mb-8 transform-gpu transition-all duration-300 group-hover:scale-110 group-hover:bg-olive-500 group-hover:text-bone shadow-sm" style="transform: translateZ(20px);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <!-- Title -->
          <h3 class="text-charcoal font-serif font-bold text-xl mb-4 transform-gpu transition-transform duration-300 group-hover:translate-x-1" style="transform: translateZ(25px);">
            <span class="lang-es">Casa Club Residencial</span><span class="lang-en">Residential Clubhouse</span>
          </h3>
          <!-- Text -->
          <p class="text-charcoal/70 font-sans text-sm leading-relaxed" style="transform: translateZ(15px);">
            <span class="lang-es">Lujosa área social con terraza, alberca templada, asadores de acero inoxidable y canchas deportivas exclusivas para colonos.</span>
            <span class="lang-en">Luxurious social area with terrace, heated pool, stainless steel grills, and sports courts exclusive to residents.</span>
          </p>
        </div>
        <div class="mt-6 flex items-center text-xs font-semibold text-olive-600 group-hover:text-olive-500 gap-1" style="transform: translateZ(20px);">
          <span class="lang-es">Más detalles</span><span class="lang-en">More details</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // 3D Tilt Effect
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.tilt-card');
    
    // Check if user is on touch device to avoid running tilt event listeners
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    
    if (!isTouchDevice) {
      cards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const ev = e as MouseEvent;
          const rect = card.getBoundingClientRect();
          
          // Mouse position relative to card boundaries
          const x = ev.clientX - rect.left;
          const y = ev.clientY - rect.top;
          
          // Find card center point
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          
          // Calculate rotation degrees (max tilt of 10 degrees)
          const rotateX = (centerY - y) / (centerY / 10);
          const rotateY = (x - centerX) / (centerX / 10);
          
          // Apply transforms (gpu-accelerated)
          (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-8px)`;
        });
        
        card.addEventListener('mouseleave', () => {
          (card as HTMLElement).style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) translateY(0px)`;
        });
      });
    }
  });
</script>
