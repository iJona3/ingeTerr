---
// Navbar.astro
---

<header class="fixed top-0 left-0 w-full z-50 px-4 py-4 md:py-6 flex justify-center transition-all duration-500" id="navbar-header">
  <nav class="w-full max-w-5xl glass-nav rounded-full px-6 py-3 md:px-8 md:py-4 flex items-center justify-between shadow-lg transition-all duration-500 scale-100" id="navbar-pill">
    <!-- Brand / Logo -->
    <a href="#inicio" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-olive-600 to-gold-500 flex items-center justify-center text-bone font-serif font-bold text-lg shadow-md">
        CR
      </div>
      <span class="text-charcoal font-serif font-bold text-lg md:text-xl tracking-wide group-hover:text-olive-500 transition-colors duration-300">
        Coronado <span class="text-olive-500 font-sans font-light">Real Estate</span>
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <div class="hidden md:flex items-center gap-8 font-sans font-medium text-sm text-charcoal/80">
      <a href="#inicio" class="nav-link relative py-1 hover:text-charcoal transition-colors duration-300">Inicio</a>
      <a href="#amenidades" class="nav-link relative py-1 hover:text-charcoal transition-colors duration-300">Amenidades</a>
      <a href="#beneficios" class="nav-link relative py-1 hover:text-charcoal transition-colors duration-300">Diferenciales</a>
      <a href="#galeria" class="nav-link relative py-1 hover:text-charcoal transition-colors duration-300">Galería</a>
      <a href="#testimonios" class="nav-link relative py-1 hover:text-charcoal transition-colors duration-300">Reseñas</a>
    </div>

    <!-- CTA Button -->
    <div class="hidden md:block">
      <a 
        href="#contacto" 
        class="bg-olive-500 hover:bg-olive-600 text-bone px-5 py-2 rounded-full font-sans font-semibold text-xs tracking-wider uppercase transition-all duration-300 shadow-md hover:shadow-olive-500/20 hover:-translate-y-0.5 block"
      >
        Cotizar Lote
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button 
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 rounded-full bg-olive-500/10 text-olive-600 focus:outline-none transition-colors" 
      id="mobile-menu-btn" 
      aria-label="Menu principal"
    >
      <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center translate-y-[-3px]" id="line1"></span>
      <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center" id="line2"></span>
      <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center translate-y-[3px]" id="line3"></span>
    </button>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div 
    class="absolute top-20 left-4 right-4 glass-nav rounded-2xl p-6 shadow-2xl flex flex-col gap-4 md:hidden opacity-0 pointer-events-none transform -translate-y-4 transition-all duration-300 z-40 border border-gold-500/20" 
    id="mobile-dropdown"
  >
    <a href="#inicio" class="mobile-link text-charcoal font-sans font-medium text-base py-2 border-b border-charcoal/5">Inicio</a>
    <a href="#amenidades" class="mobile-link text-charcoal font-sans font-medium text-base py-2 border-b border-charcoal/5">Amenidades</a>
    <a href="#beneficios" class="mobile-link text-charcoal font-sans font-medium text-base py-2 border-b border-charcoal/5">Diferenciales</a>
    <a href="#galeria" class="mobile-link text-charcoal font-sans font-medium text-base py-2 border-b border-charcoal/5">Galería</a>
    <a href="#testimonios" class="mobile-link text-charcoal font-sans font-medium text-base py-2 border-b border-charcoal/5">Reseñas</a>
    <a 
      href="#contacto" 
      class="mobile-link bg-olive-500 text-bone text-center py-3 rounded-full font-sans font-semibold text-sm shadow-md mt-2"
    >
      Cotizar Lote
    </a>
  </div>
</header>

<style>
  /* Underline animation on desktop nav links */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-olive-500);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  // Navbar Scroll shrink effect and mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const navbarHeader = document.getElementById('navbar-header');
    const navbarPill = document.getElementById('navbar-pill');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileDropdown = document.getElementById('mobile-dropdown');
    
    // Mobile Button Lines
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    // 1. Scroll effect
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        navbarHeader?.classList.remove('py-4', 'md:py-6');
        navbarHeader?.classList.add('py-2', 'md:py-3');
        navbarPill?.classList.remove('scale-100');
        navbarPill?.classList.add('scale-95', 'shadow-md');
        navbarPill?.classList.add('py-2', 'px-5', 'md:px-6', 'md:py-3');
        navbarPill?.classList.remove('py-3', 'px-6', 'md:px-8', 'md:py-4');
      } else {
        navbarHeader?.classList.remove('py-2', 'md:py-3');
        navbarHeader?.classList.add('py-4', 'md:py-6');
        navbarPill?.classList.remove('scale-95', 'shadow-md');
        navbarPill?.classList.add('scale-100');
        navbarPill?.classList.remove('py-2', 'px-5', 'md:px-6', 'md:py-3');
        navbarPill?.classList.add('py-3', 'px-6', 'md:px-8', 'md:py-4');
      }
    });

    // 2. Toggle Mobile Menu
    if (mobileBtn && mobileDropdown) {
      const toggleMenu = () => {
        const isOpen = mobileDropdown.classList.contains('opacity-100');
        
        if (isOpen) {
          // Close
          mobileDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('rotate-45', 'translate-y-[1px]');
          line1?.classList.add('translate-y-[-3px]');
          line2?.classList.remove('opacity-0');
          line3?.classList.remove('-rotate-45', 'translate-y-[-1px]');
          line3?.classList.add('translate-y-[3px]');
        } else {
          // Open
          mobileDropdown.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('translate-y-[-3px]');
          line1?.classList.add('rotate-45', 'translate-y-[1px]');
          line2?.classList.add('opacity-0');
          line3?.classList.remove('translate-y-[3px]');
          line3?.classList.add('-rotate-45', 'translate-y-[-1px]');
        }
      };

      mobileBtn.addEventListener('click', toggleMenu);

      // Close mobile menu when clicking any link
      const links = mobileDropdown.querySelectorAll('.mobile-link');
      links.forEach(link => {
        link.addEventListener('click', () => {
          // Force close
          mobileDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('rotate-45', 'translate-y-[1px]');
          line1?.classList.add('translate-y-[-3px]');
          line2?.classList.remove('opacity-0');
          line3?.classList.remove('-rotate-45', 'translate-y-[-1px]');
          line3?.classList.add('translate-y-[3px]');
        });
      });
    }
  });
</script>
