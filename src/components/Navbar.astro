---
// Navbar.astro
import { Image } from 'astro:assets';
import logoImg from '../assets/images/coronado-logo.png';
---

<header class="fixed top-0 left-0 w-full z-50 px-4 py-4 md:py-6 flex justify-center transition-all duration-500" id="navbar-header">
  <nav 
    class="w-full max-w-5xl rounded-full px-6 py-3 md:px-8 md:py-4 flex items-center justify-between shadow-lg transition-all duration-500 scale-100 bg-black/25 border border-white/10 backdrop-blur-xl text-white" 
    id="navbar-pill"
  >
      <Image
        id="logo-img"
        src={logoImg}
        alt="Coronado Real Estate logo"
        class="h-9 w-auto object-contain group-hover:scale-105 transition-transform duration-300"
        style="max-width: 44px;"
        width={88}
        height={88}
      />
      <span 
        id="brand-name"
        class="text-white font-serif font-bold text-base md:text-lg tracking-wide transition-colors duration-300 leading-tight"
      >
        Coronado <span id="brand-subname" class="text-gold-500 font-sans font-light text-sm">Real Estate</span>
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <div 
      id="nav-links-container"
      class="hidden md:flex items-center gap-8 font-sans font-medium text-sm text-white/80"
    >
      <a href="#inicio" class="nav-link relative py-1 hover:text-white transition-colors duration-300">
        <span class="lang-es">Inicio</span><span class="lang-en">Home</span>
      </a>
      <a href="#amenidades" class="nav-link relative py-1 hover:text-white transition-colors duration-300">
        <span class="lang-es">Amenidades</span><span class="lang-en">Amenities</span>
      </a>
      <a href="#beneficios" class="nav-link relative py-1 hover:text-white transition-colors duration-300">
        <span class="lang-es">Diferenciales</span><span class="lang-en">Benefits</span>
      </a>
      <a href="#galeria" class="nav-link relative py-1 hover:text-white transition-colors duration-300">
        <span class="lang-es">Galería</span><span class="lang-en">Gallery</span>
      </a>
      <a href="#testimonios" class="nav-link relative py-1 hover:text-white transition-colors duration-300">
        <span class="lang-es">Reseñas</span><span class="lang-en">Reviews</span>
      </a>
    </div>

    <!-- CTA Button and Lang Switcher -->
    <div class="hidden md:flex items-center gap-4">
      <a 
        id="cta-btn"
        href="#contacto" 
        class="bg-white hover:bg-white/90 text-charcoal px-5 py-2.5 rounded-full font-sans font-semibold text-xs tracking-wider uppercase transition-all duration-300 shadow-md hover:-translate-y-0.5 block"
      >
        <span class="lang-es">Cotizar Lote</span><span class="lang-en">Get a Quote</span>
      </a>
      
      <button 
        id="lang-toggle-btn"
        class="flex items-center justify-center w-9 h-9 rounded-full border border-white/20 text-[10px] font-bold tracking-wider uppercase transition-all duration-300 hover:bg-white/10 cursor-pointer select-none"
        aria-label="Cambiar idioma / Change language"
      >
        <span class="lang-es">EN</span><span class="lang-en">ES</span>
      </button>
    </div>

    <!-- Mobile: Lang button + Hamburger button -->
    <div class="md:hidden flex items-center gap-2">
      <button 
        id="lang-toggle-btn-mobile"
        class="flex items-center justify-center w-9 h-9 rounded-full border border-white/20 text-[10px] font-bold tracking-wider uppercase transition-all duration-300 hover:bg-white/10 cursor-pointer select-none text-white"
        aria-label="Cambiar idioma / Change language"
      >
        <span class="lang-es">EN</span><span class="lang-en">ES</span>
      </button>
      <button 
        class="flex flex-col justify-center items-center w-8 h-8 rounded-full bg-white/10 text-white focus:outline-none transition-colors" 
        id="mobile-menu-btn" 
        aria-label="Menu principal"
      >
        <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center translate-y-[-3px]" id="line1"></span>
        <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center" id="line2"></span>
        <span class="w-4 h-0.5 bg-current rounded transition-all duration-300 origin-center translate-y-[3px]" id="line3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown (Initially matching the transparent dark look) -->
  <div 
    class="absolute top-20 left-4 right-4 bg-charcoal/95 backdrop-blur-xl border border-white/10 text-white rounded-2xl p-6 shadow-2xl flex flex-col gap-4 md:hidden opacity-0 pointer-events-none transform -translate-y-4 transition-all duration-300 z-40" 
    id="mobile-dropdown"
  >
    <a href="#inicio" class="mobile-link text-white/90 font-sans font-medium text-base py-2 border-b border-white/5">
      <span class="lang-es">Inicio</span><span class="lang-en">Home</span>
    </a>
    <a href="#amenidades" class="mobile-link text-white/90 font-sans font-medium text-base py-2 border-b border-white/5">
      <span class="lang-es">Amenidades</span><span class="lang-en">Amenities</span>
    </a>
    <a href="#beneficios" class="mobile-link text-white/90 font-sans font-medium text-base py-2 border-b border-white/5">
      <span class="lang-es">Diferenciales</span><span class="lang-en">Benefits</span>
    </a>
    <a href="#galeria" class="mobile-link text-white/90 font-sans font-medium text-base py-2 border-b border-white/5">
      <span class="lang-es">Galería</span><span class="lang-en">Gallery</span>
    </a>
    <a href="#testimonios" class="mobile-link text-white/90 font-sans font-medium text-base py-2 border-b border-white/5">
      <span class="lang-es">Reseñas</span><span class="lang-en">Reviews</span>
    </a>
    <a 
      href="#contacto" 
      class="mobile-link bg-white text-charcoal text-center py-3 rounded-full font-sans font-semibold text-sm shadow-md mt-2"
    >
      <span class="lang-es">Cotizar Lote</span><span class="lang-en">Get a Quote</span>
    </a>

  </div>
</header>

<style>
  /* Underline animation on desktop nav links */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  // Navbar Scroll shrink effect and mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const navbarHeader = document.getElementById('navbar-header');
    const navbarPill = document.getElementById('navbar-pill');
    const logoImg = document.getElementById('logo-img');
    const brandName = document.getElementById('brand-name');
    const brandSubname = document.getElementById('brand-subname');
    const navLinksContainer = document.getElementById('nav-links-container');
    const navLinks = navLinksContainer?.querySelectorAll('.nav-link');
    const ctaBtn = document.getElementById('cta-btn');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileDropdown = document.getElementById('mobile-dropdown');
    
    // Mobile Button Lines
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    // 1. Scroll effect & Theme transition
    const handleScroll = () => {
      if (window.scrollY > 40) {
        // Shrink Nav Header Wrapper
        navbarHeader?.classList.remove('py-4', 'md:py-6');
        navbarHeader?.classList.add('py-2', 'md:py-3');
        
        // Transition Pill to Light Glassmorphism
        navbarPill?.classList.remove('bg-black/25', 'border-white/10', 'text-white', 'scale-100');
        navbarPill?.classList.add('glass-nav', 'text-charcoal', 'scale-95', 'shadow-md');
        navbarPill?.classList.remove('py-3', 'px-6', 'md:px-8', 'md:py-4');
        navbarPill?.classList.add('py-2', 'px-5', 'md:px-6', 'md:py-3');

        // Transition Brand Text
        brandName?.classList.remove('text-white');
        brandName?.classList.add('text-charcoal');
        brandSubname?.classList.remove('text-gold-500');
        brandSubname?.classList.add('text-olive-500');

        // Transition Links
        navLinksContainer?.classList.remove('text-white/80');
        navLinksContainer?.classList.add('text-charcoal/80');
        navLinks?.forEach(link => {
          link.classList.remove('hover:text-white');
          link.classList.add('hover:text-charcoal');
        });

        // Transition CTA button
        ctaBtn?.classList.remove('bg-white', 'text-charcoal', 'hover:bg-white/90');
        ctaBtn?.classList.add('bg-olive-500', 'text-bone', 'hover:bg-olive-600');

        // Transition Lang Switcher Buttons
        const langBtn = document.getElementById('lang-toggle-btn');
        langBtn?.classList.remove('border-white/20', 'text-white', 'hover:bg-white/10');
        langBtn?.classList.add('border-charcoal/20', 'text-charcoal', 'hover:bg-charcoal/5');
        const langBtnMobile = document.getElementById('lang-toggle-btn-mobile');
        langBtnMobile?.classList.remove('border-white/20', 'text-white', 'hover:bg-white/10');
        langBtnMobile?.classList.add('border-charcoal/20', 'text-charcoal', 'hover:bg-charcoal/5');

        // Mobile hamburger button
        mobileBtn?.classList.remove('bg-white/10', 'text-white');
        mobileBtn?.classList.add('bg-olive-500/10', 'text-olive-600');

      } else {
        // Expand Nav Header Wrapper
        navbarHeader?.classList.remove('py-2', 'md:py-3');
        navbarHeader?.classList.add('py-4', 'md:py-6');
        
        // Transition Pill to Transparent Dark
        navbarPill?.classList.add('bg-black/25', 'border-white/10', 'text-white', 'scale-100');
        navbarPill?.classList.remove('glass-nav', 'text-charcoal', 'scale-95', 'shadow-md');
        navbarPill?.classList.remove('py-2', 'px-5', 'md:px-6', 'md:py-3');
        navbarPill?.classList.add('py-3', 'px-6', 'md:px-8', 'md:py-4');

        // Transition Brand Text
        brandName?.classList.remove('text-charcoal');
        brandName?.classList.add('text-white');
        brandSubname?.classList.remove('text-olive-500');
        brandSubname?.classList.add('text-gold-500');

        // Transition Links
        navLinksContainer?.classList.remove('text-charcoal/80');
        navLinksContainer?.classList.add('text-white/80');
        navLinks?.forEach(link => {
          link.classList.remove('hover:text-charcoal');
          link.classList.add('hover:text-white');
        });

        // Transition CTA button
        ctaBtn?.classList.add('bg-white', 'text-charcoal', 'hover:bg-white/90');
        ctaBtn?.classList.remove('bg-olive-500', 'text-bone', 'hover:bg-olive-600');

        // Transition Lang Switcher Buttons
        const langBtn = document.getElementById('lang-toggle-btn');
        langBtn?.classList.remove('border-charcoal/20', 'text-charcoal', 'hover:bg-charcoal/5');
        langBtn?.classList.add('border-white/20', 'text-white', 'hover:bg-white/10');
        const langBtnMobile = document.getElementById('lang-toggle-btn-mobile');
        langBtnMobile?.classList.remove('border-charcoal/20', 'text-charcoal', 'hover:bg-charcoal/5');
        langBtnMobile?.classList.add('border-white/20', 'text-white', 'hover:bg-white/10');

        // Mobile hamburger button
        mobileBtn?.classList.add('bg-white/10', 'text-white');
        mobileBtn?.classList.remove('bg-olive-500/10', 'text-olive-600');
      }
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Trigger initial layout state

    // 2. Toggle Mobile Menu
    if (mobileBtn && mobileDropdown) {
      const toggleMenu = () => {
        const isOpen = mobileDropdown.classList.contains('opacity-100');
        
        if (isOpen) {
          // Close
          mobileDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('rotate-45', 'translate-y-[1px]');
          line1?.classList.add('translate-y-[-3px]');
          line2?.classList.remove('opacity-0');
          line3?.classList.remove('-rotate-45', 'translate-y-[-1px]');
          line3?.classList.add('translate-y-[3px]');
        } else {
          // Open
          mobileDropdown.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('translate-y-[-3px]');
          line1?.classList.add('rotate-45', 'translate-y-[1px]');
          line2?.classList.add('opacity-0');
          line3?.classList.remove('translate-y-[3px]');
          line3?.classList.add('-rotate-45', 'translate-y-[-1px]');
        }
      };

      mobileBtn.addEventListener('click', toggleMenu);

      // Close mobile menu when clicking any link
      const links = mobileDropdown.querySelectorAll('.mobile-link');
      links.forEach(link => {
        link.addEventListener('click', () => {
          // Force close
          mobileDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
          mobileDropdown.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
          
          line1?.classList.remove('rotate-45', 'translate-y-[1px]');
          line1?.classList.add('translate-y-[-3px]');
          line2?.classList.remove('opacity-0');
          line3?.classList.remove('-rotate-45', 'translate-y-[-1px]');
          line3?.classList.add('translate-y-[3px]');
        });
      });
    }

    // 3. Language Switching Logic
    const toggleButtons = [
      document.getElementById('lang-toggle-btn'),
      document.getElementById('lang-toggle-btn-mobile')
    ];

    const changeLanguage = (lang: string) => {
      if (lang === 'en') {
        document.documentElement.classList.add('lang-en');
      } else {
        document.documentElement.classList.remove('lang-en');
      }
      localStorage.setItem('preferred-lang', lang);
      window.dispatchEvent(new CustomEvent('langChanged', { detail: { lang } }));
    };

    toggleButtons.forEach(btn => {
      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const currentLang = document.documentElement.classList.contains('lang-en') ? 'en' : 'es';
        const newLang = currentLang === 'en' ? 'es' : 'en';
        changeLanguage(newLang);
      });
    });
  });
</script>
