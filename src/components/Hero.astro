---
// Hero.astro
// Componente de encabezado principal adaptado al diseño de referencia provisto
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.png';
import previewImg from '../assets/images/8cf88e542d5b97d7a14bc8b3e6bbe57d.jpg';
---

<section 
  id="inicio" 
  class="relative min-h-screen w-full flex items-center justify-center overflow-hidden bg-charcoal"
>
  <!-- Background Image with parallax overlay -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={heroBg} 
      alt="Desarrollo residencial premium Coronado Real Estate" 
      class="w-full h-full object-cover object-center scale-105"
      id="hero-bg-img"
      loading="eager"
      fetchpriority="high"
      width={1920}
    />
    <!-- Premium Overlay: dark gradient to ensure legibility -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/45 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/40"></div>
  </div>

  <!-- Ambient Light Blobs -->
  <div class="absolute top-1/3 left-[-10%] w-[50vw] h-[50vw] rounded-full bg-gold-500/10 blur-[130px] pointer-events-none z-1"></div>
  <div class="absolute bottom-10 right-[-10%] w-[40vw] h-[40vw] rounded-full bg-olive-500/10 blur-[120px] pointer-events-none z-1"></div>

  <!-- Main Content Container -->
  <div class="container mx-auto px-4 sm:px-6 md:px-8 max-w-7xl relative z-10 pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center min-h-[70vh]">
      
      <!-- Text Column (Left) -->
      <div class="lg:col-span-7 flex flex-col items-start text-left reveal-left">
        <!-- Floating Tag/Slogan -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-gold-100 font-sans font-semibold text-xs tracking-wider uppercase mb-6 backdrop-blur-md">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-500 animate-ping"></span>
          Coronado Real Estate • Saltillo, Coah.
        </div>
        
        <!-- Main Title (Based on reference) -->
        <h1 class="text-white text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-serif leading-[1.1] mb-6 tracking-tight">
          <span class="lang-es">
            Diseñando Sueños,<br class="hidden sm:inline"/>
            Construyendo Futuros<br/>
            con <span class="text-gold-500 italic font-normal font-serif">Elegancia</span> e <span class="text-gold-500 italic font-normal font-serif">Innovación</span>
          </span>
          <span class="lang-en">
            Designing Dreams,<br class="hidden sm:inline"/>
            Building Futures<br/>
            with <span class="text-gold-500 italic font-normal font-serif">Elegance</span> and <span class="text-gold-500 italic font-normal font-serif">Innovation</span>
          </span>
        </h1>
        
        <!-- Description -->
        <p class="text-white/80 font-sans text-base md:text-lg leading-relaxed max-w-xl mb-10">
          <span class="lang-es">Descubre un fraccionamiento residencial exclusivo en Saltillo, Coahuila. Lotes urbanizados premium listos para construir el hogar que tu familia merece, rodeados de naturaleza y confort.</span>
          <span class="lang-en">Discover an exclusive residential development in Saltillo, Coahuila. Premium urbanized lots ready to build the home your family deserves, surrounded by nature and comfort.</span>
        </p>
        
        <!-- Action Button (Play Video style from reference) -->
        <button 
          id="play-video-btn"
          class="inline-flex items-center gap-3.5 bg-white hover:bg-white/95 text-charcoal px-8 py-4 rounded-full font-sans font-bold text-xs sm:text-sm tracking-wider uppercase transition-all duration-300 shadow-2xl hover:shadow-white/20 hover:-translate-y-1 cursor-pointer group"
        >
          <!-- Play Circle Icon -->
          <span class="w-8 h-8 rounded-full bg-charcoal text-white flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-current ml-0.5" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </span>
          <span class="lang-es">Conocer el Proyecto</span>
          <span class="lang-en">Explore the Project</span>
        </button>
      </div>
      
      <!-- Cards Column (Right - Based on reference) -->
      <div class="lg:col-span-5 flex flex-col gap-6 justify-center w-full max-w-[460px] mx-auto lg:ml-auto reveal-right relative z-10">
        
        <!-- Card 1 (Metric - Simple) -->
        <a 
          href="#amenidades" 
          class="group relative flex flex-col justify-between p-6 md:p-8 rounded-3xl bg-black/45 backdrop-blur-xl border border-white/10 hover:border-white/20 shadow-2xl transition-all duration-500 hover:-translate-y-1 hover:shadow-black/40 overflow-hidden cursor-pointer"
        >
          <!-- Shiny light effect -->
          <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/5 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          
          <div class="flex justify-between items-start w-full">
            <div class="flex flex-col">
              <span class="text-white font-serif font-bold text-2xl sm:text-3xl tracking-tight">
                <span class="lang-es">100% Urbanizado</span>
                <span class="lang-en">100% Urbanized</span>
              </span>
              <span class="text-gold-500 font-sans text-xs font-medium tracking-wider uppercase mt-1">
                <span class="lang-es">Servicios subterráneos de primer nivel</span>
                <span class="lang-en">Premium underground utilities</span>
              </span>
            </div>
            
            <!-- Arrow Oblique Icon -->
            <span class="w-10 h-10 rounded-full border border-white/20 text-white flex items-center justify-center transition-all duration-300 group-hover:bg-white group-hover:text-charcoal group-hover:border-white transform group-hover:translate-x-1 group-hover:-translate-y-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" class="hidden" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7V15" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card 2 (Visual with image thumbnail) -->
        <a 
          href="#galeria" 
          class="group relative flex flex-col p-5 md:p-6 rounded-3xl bg-black/45 backdrop-blur-xl border border-white/10 hover:border-white/20 shadow-2xl transition-all duration-500 hover:-translate-y-1 hover:shadow-black/40 overflow-hidden cursor-pointer"
        >
          <!-- Image Container inside Card -->
          <div class="w-full aspect-[16/9] rounded-2xl overflow-hidden mb-5 border border-white/5 relative">
            <Image 
              src={previewImg} 
              alt="Sierra de Saltillo Coronado Real Estate" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              width={400}
              height={225}
            />
            <div class="absolute inset-0 bg-black/10"></div>
          </div>

          <div class="flex justify-between items-end w-full">
            <div class="flex flex-col">
              <span class="text-white font-serif font-bold text-xl sm:text-2xl tracking-tight">
                <span class="lang-es">Vistas Espectaculares</span>
                <span class="lang-en">Spectacular Views</span>
              </span>
              <span class="text-white/60 font-sans text-xs tracking-wide mt-1">
                <span class="lang-es">Explora un entorno natural único al pie de la Sierra.</span>
                <span class="lang-en">Explore a unique natural environment at the foot of the mountains.</span>
              </span>
            </div>
            
            <!-- Arrow Oblique Icon -->
            <span class="w-10 h-10 rounded-full border border-white/20 text-white flex items-center justify-center transition-all duration-300 group-hover:bg-white group-hover:text-charcoal group-hover:border-white flex-shrink-0 ml-4 transform group-hover:translate-x-1 group-hover:-translate-y-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7V15" />
              </svg>
            </span>
          </div>
        </a>

      </div>
      
    </div>
  </div>

  <!-- Ambient Bottom Fade -->
  <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-bone to-transparent z-1"></div>
</section>

<!-- Cinematic Video Modal (Wow factor overlay) -->
<div 
  id="video-modal" 
  class="fixed inset-0 z-[100] bg-charcoal/95 backdrop-blur-md flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
  role="dialog"
  aria-modal="true"
>
  <!-- Close Button -->
  <button 
    id="close-video-modal" 
    class="absolute top-6 right-6 w-12 h-12 rounded-full bg-bone/10 hover:bg-bone/20 text-bone flex items-center justify-center text-2xl focus:outline-none transition-colors cursor-pointer"
    aria-label="Cerrar video"
  >
    &times;
  </button>

  <!-- Video Iframe Container (Responsive 16:9) -->
  <div class="w-full max-w-4xl max-h-[80vh] px-4">
    <div class="relative aspect-[16/9] w-full rounded-2xl overflow-hidden shadow-2xl border border-white/10">
      <!-- High quality drone real estate footage (Saltillo or mountain residential context placeholder) -->
      <iframe 
        id="modal-iframe"
        class="absolute inset-0 w-full h-full" 
        src="" 
        title="Coronado Real Estate Presentación" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<style>
  /* Subtle Parallax background adjustment */
  #hero-bg-img {
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Parallax background movement
    const heroSection = document.getElementById('inicio');
    const heroBgImg = document.getElementById('hero-bg-img');

    if (heroSection && heroBgImg) {
      heroSection.addEventListener('mousemove', (e: MouseEvent) => {
        const { width, height } = heroSection.getBoundingClientRect();
        const moveX = (e.clientX - width / 2) / width * 10;
        const moveY = (e.clientY - height / 2) / height * 10;
        heroBgImg.style.transform = `scale(1.05) translate(${-moveX}px, ${-moveY}px)`;
      });
      
      heroSection.addEventListener('mouseleave', () => {
        heroBgImg.style.transform = 'scale(1.05) translate(0px, 0px)';
      });
    }

    // Video Modal Open/Close Logic
    const playBtn = document.getElementById('play-video-btn');
    const videoModal = document.getElementById('video-modal');
    const closeBtn = document.getElementById('close-video-modal');
    const modalIframe = document.getElementById('modal-iframe') as HTMLIFrameElement;

    // Cinematic real estate drone loop or showcase video URL (YouTube Embed)
    const videoUrl = 'https://www.youtube.com/embed/5PSNL1yE68Y?autoplay=1&rel=0';

    if (playBtn && videoModal && closeBtn && modalIframe) {
      const openModal = () => {
        modalIframe.src = videoUrl;
        videoModal.classList.remove('opacity-0', 'pointer-events-none');
        videoModal.classList.add('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        modalIframe.src = '';
        videoModal.classList.add('opacity-0', 'pointer-events-none');
        videoModal.classList.remove('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = '';
      };

      playBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);

      // Close on clicking outside container
      videoModal.addEventListener('click', (e) => {
        if (e.target === videoModal) {
          closeModal();
        }
      });

      // Escape key to close
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && videoModal.classList.contains('opacity-100')) {
          closeModal();
        }
      });
    }
  });
</script>
