---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Coronado Real Estate | Exclusivos Terrenos Residenciales en Saltillo Coahuila",
	description = "Adquiere tu terreno residencial en la mejor zona de crecimiento de Saltillo, Coahuila. Terrenos con servicios subterráneos, áreas verdes y financiamiento. ¡Reserva hoy!"
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- SEO Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/images/8cf88e542d5b97d7a14bc8b3e6bbe57d.jpg" />
		
		<!-- Preconnect to Font APIs -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />
		
		<!-- Initial Language Setup -->
		<script is:inline>
			(function() {
				const savedLang = localStorage.getItem('preferred-lang') || 
					(navigator.language && navigator.language.startsWith('en') ? 'en' : 'es');
				if (savedLang === 'en') {
					document.documentElement.classList.add('lang-en');
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		
		<!-- Global Scroll Reveal Script -->
		<script>
			const initScrollReveal = () => {
				const reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
				
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
							observer.unobserve(entry.target);
						}
					});
				}, {
					threshold: 0.05,
					rootMargin: "0px 0px -30px 0px"
				});
				
				reveals.forEach(reveal => {
					observer.observe(reveal);
				});
			};

			// Run on DOMContentLoaded
			document.addEventListener('DOMContentLoaded', initScrollReveal);
		</script>
	</body>
</html>
